VITE_API_BASE_URL=/api/v1
VITE_DEV_PROXY_TARGET=http://localhost:8080
VITE_DEV_PORT=3000

# Docker runtime reverse proxy target used by nginx/default.conf.template.
# Use http://host.docker.internal:8080 when the official sub2api container
# publishes port 8080 on the host. Use http://sub2api:8080 when both services
# share a Docker network.
SUB2API_BACKEND=http://host.docker.internal:8080
FRONTEND_PORT=8081
FRONTEND_BIND_HOST=0.0.0.0
CLIENT_MAX_BODY_SIZE=100m
